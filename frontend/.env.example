# Copy to .env.local and fill in:  cp .env.example .env.local
# These are Vite build-time vars (must be prefixed VITE_) and are embedded in
# the client bundle, so only put public-safe values here.

# Base URL of the Go API (Terraform generation / review proxy).
# Local dev: http://localhost:8080 — Production: your Railway Go service URL.
VITE_API_URL=http://localhost:8080

# Supabase project — enables sign-in and cloud project storage.
# Find these in Supabase dashboard → Project Settings → API.
# The anon key is public-safe (Row-Level Security protects the data).
# Leave both blank to run anonymously (localStorage only).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
