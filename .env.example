# Copy to .env and fill in your values:  cp .env.example .env

# Anthropic API key used by the Python AI service for Terraform generation
# and the architecture review agent. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Comma-separated CORS origins the Go API will accept (used by docker-compose).
# Local default is the Vite dev server; in production set this to your deployed
# frontend origin (e.g. https://your-app.vercel.app).
ALLOWED_ORIGINS=http://localhost:5173
